import { IconButton, IconButtonKind } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { UiState } from "../ui-state.slint";

export component ConversionQueueToolbar inherits HorizontalLayout {
    alignment: space-between;
    height: 38px;

    HorizontalLayout {
        spacing: 5px;
        cross-axis-alignment: CrossAxisAlignment.center;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Conversion queue";
            font-size: 18px;
        }
    }

    VerticalLayout {
        alignment: center;

        if UiState.conversion-queue.length > 0: IconButton {
            icon: IconSet.X;
            label: "Cancel all conversions";
            kind: IconButtonKind.Primary;
            clicked => {
                UiState.confirming-cancel-all = true;
            }
        }
    }
}
