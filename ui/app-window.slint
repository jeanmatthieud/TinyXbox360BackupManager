import { Palette } from "std-widgets.slint";
import { Navbar } from "components/navbar.slint";
import { GameGridPage } from "game-grid-page.slint";
import { SettingsPage } from "settings-page.slint";
import { AboutPage } from "about-page.slint";
import {
    Page,
    DisplayedGame,
    DisplayedHomebrewApp,
    DisplayedOscApp,
} from "types.slint";
import { Message, Dispatcher } from "messages.slint";
import { MyPalette } from "styling.slint";
import { VerticalLine } from "components/vertical-line.slint";
import { Card } from "components/card.slint";
import { GameTablePage } from "game-table-page.slint";
import { Notifications } from "components/notifications.slint";
import { GameInfoModal } from "components/game-info-modal.slint";
import { HomebrewAppsGridPage } from "homebrew-apps-grid-page.slint";
import { HomebrewAppInfoModal } from "components/homebrew-app-info-modal.slint";
import { HomebrewAppsTablePage } from "homebrew-apps-table-page.slint";
import { OscGridPage } from "osc-grid-page.slint";
import { OscTablePage } from "osc-table-page.slint";
import { OscAppInfoModal } from "components/osc-app-info-modal.slint";
import { ConfirmationModal } from "components/confirmation-modal.slint";
import { Tooltip } from "tooltip.slint";
import { ToolboxPage } from "toolbox-page.slint";
import { ConversionQueuePage } from "conversion-queue.slint";
import { WiiloadOscAppModal } from "components/wiiload-osc-app-modal.slint";
import { UiState } from "ui-state.slint";

export * from "types.slint";
export { UiState, Message, Dispatcher }

export component AppWindow inherits Window {
    min-width: 800px;
    min-height: 600px;
    background: MyPalette.background;
    title: UiState.drive-info.label.is-empty ? "TinyWiiBackupManager  ›  No drive selected" : "TinyWiiBackupManager  ›  \{UiState.drive-info.label}  (\{UiState.drive-info.used-gib.to-fixed(2)}/\{UiState.drive-info.total-gib.to-fixed(2)} GiB)";
    default-font-size: 14px;
    icon: @image-url("../package/windows/TinyWiiBackupManager-64x64.png");

    // Initialize
    Timer {
        interval: 100ms;
        running: true;

        triggered => {
            if UiState.config.theme-preference == "Light" {
                Palette.color-scheme = ColorScheme.light;
            } else if UiState.config.theme-preference == "Dark" {
                Palette.color-scheme = ColorScheme.dark;
            }
            if Palette.color-scheme == ColorScheme.dark {
                Dispatcher.dispatch(Message.SetWindowColorDark, "");
            } else {
                Dispatcher.dispatch(Message.SetWindowColorLight, "");
            }

            Dispatcher.dispatch(Message.CacheOscContents, "false");
            Dispatcher.dispatch(Message.CheckForUpdates, "");
            Dispatcher.dispatch(Message.CheckMountPoint, "");

            self.running = false;
        }
    }

    HorizontalLayout {
        Navbar { }

        VerticalLayout {
            Rectangle {
                background: MyPalette.alternate-background;
                border-top-left-radius: 10px;
                border-width: 1px;
                border-color: MyPalette.border;

                if UiState.current-page == Page.Games && UiState.config.view-as == "Grid": GameGridPage { }
                if UiState.current-page == Page.Games && UiState.config.view-as == "Table": GameTablePage { }
                if UiState.current-page == Page.HomebrewApps && UiState.config.view-as == "Grid": HomebrewAppsGridPage { }
                if UiState.current-page == Page.HomebrewApps && UiState.config.view-as == "Table": HomebrewAppsTablePage { }
                if UiState.current-page == Page.Osc && UiState.config.view-as == "Grid": OscGridPage { }
                if UiState.current-page == Page.Osc && UiState.config.view-as == "Table": OscTablePage { }
                if UiState.current-page == Page.Toolbox: ToolboxPage { }
                if UiState.current-page == Page.ConversionQueue: ConversionQueuePage { }
                if UiState.current-page == Page.Settings: SettingsPage { }
                if UiState.current-page == Page.About: AboutPage { }
            }

            if !UiState.status.is-empty: HorizontalLayout {
                VerticalLine { }

                HorizontalLayout {
                    padding: 10px;

                    Text {
                        text: UiState.status;
                    }
                }
            }
        }
    }

    if !UiState.current-game.path.is-empty: GameInfoModal { }
    if !UiState.current-homebrew-app.path.is-empty: HomebrewAppInfoModal { }
    if !UiState.current-osc-app.slug.is-empty: OscAppInfoModal { }
    if !UiState.wiiloading-osc-app.slug.is-empty: WiiloadOscAppModal { }

    if !UiState.game-to-delete.path.is-empty: ConfirmationModal {
        Text {
            text: "Are you sure you want to delete \{UiState.game-to-delete.title}?\nThis action cannot be undone.";
        }

        cancelled => {
            UiState.game-to-delete = { };
        }
        confirmed => {
            Dispatcher.dispatch(Message.DeleteGame, UiState.game-to-delete.path);
            UiState.game-to-delete = { };
        }
    }

    if !UiState.homebrew-app-to-delete.name.is-empty: ConfirmationModal {
        Text {
            text: "Are you sure you want to delete \{UiState.homebrew-app-to-delete.name}?\nThis action cannot be undone.";
        }

        cancelled => {
            UiState.homebrew-app-to-delete = { };
        }
        confirmed => {
            Dispatcher.dispatch(Message.DeleteHomebrewApp, UiState.homebrew-app-to-delete.path);
            UiState.homebrew-app-to-delete = { };
        }
    }

    if UiState.games-to-add.length > 0: ConfirmationModal {
        Text {
            text: "Are you sure you want to add \{UiState.games-to-add.length} conversions to the queue?";
        }

        for path in UiState.games-to-add: Text {
            text: "• \{path}";
        }

        cancelled => Dispatcher.dispatch(Message.ClearGamesToAdd, "");
        confirmed => Dispatcher.dispatch(Message.ConfirmGamesToAdd, "");
    }

    if UiState.scrubbing-current-game: ConfirmationModal {
        Text {
            text: "Are you sure you want to scrub \{UiState.current-game.title}?\nThis action cannot be undone.";
        }

        cancelled => {
            UiState.scrubbing-current-game = false;
        }
        confirmed => {
            Dispatcher.dispatch(Message.ScrubGame, UiState.current-game.path);
            UiState.scrubbing-current-game = false;
            UiState.current-game = { };
            UiState.crc32-status = "";
            UiState.current-disc-info = { };
        }
    }

    if UiState.scrubbing-all-games: ConfirmationModal {
        Text {
            text: "Are you sure you want to scrub all games?\nThis action cannot be undone.";
        }

        cancelled => {
            UiState.scrubbing-all-games = false;
        }
        confirmed => {
            Dispatcher.dispatch(Message.ScrubAllGames, "");
            UiState.scrubbing-all-games = false;
        }
    }

    if UiState.notifications.length > 0: Notifications {
        x: root.width - self.width;
        y: root.height - self.height;
    }

    if !Tooltip.text.is-empty: Card {
        x: Tooltip.mouse-x + t.preferred-width + 18px > root.width ? Tooltip.mouse-x - t.preferred-width - 18px : Tooltip.mouse-x;
        y: Tooltip.mouse-y;

        width: t.preferred-width + 18px;
        height: t.preferred-height + 16px;

        HorizontalLayout {
            padding-top: 8px;
            padding-bottom: 8px;
            padding-left: 9px;
            padding-right: 9px;

            t := Text {
                text: Tooltip.text;
            }
        }
    }
}
