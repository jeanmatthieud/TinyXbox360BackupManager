export enum Page {
    Games,
    Toolbox,
    ConversionQueue,
    Settings,
    About,
}

export enum TargetKind {
    Local,
    Ftp,
}

export struct DisplayedConfig {
    path: string,
    // Displayed target: local path or ftp://ip. Empty if no target.
    target: string,
    target-kind: TargetKind,
    mount-point: string,
    remove-sources-games: string,
    sort-by: string,
    view-as: string,
    theme-preference: string,
    show-x360: bool,
    show-og: bool,
    console-ip: string,
    ftp-port: string,
    ftp-user: string,
    ftp-password: string,
}

export struct DisplayedGame {
    path: string,
    is-x360: bool,
    format: string,
    size-gib: float,
    title: string,
    id: string,
    cover: image,
}

export struct DisplayedDriveInfo {
    label: string,
    used-gib: float,
    games-gib: float,
    total-gib: float,
    fs-kind: string,
    allocation-granularity: int,
}

export struct Notification {
    text: string,
    critical: bool,
}
