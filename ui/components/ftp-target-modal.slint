import { LineEdit, Spinner } from "std-widgets.slint";
import { Modal } from "modal.slint";
import { HorizontalLine } from "horizontal-line.slint";
import { IconButton, IconButtonKind } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component FtpTargetModal inherits Modal {
    // On open, look for the console on the network before falling back to
    // manual entry.
    init => {
        UiState.ftp-show-manual = false;
        Dispatcher.dispatch(Message.StartFtpScan, "");
    }

    VerticalLayout {
        padding: 20px;
        spacing: 10px;

        Text {
            text: "Console internal drive over FTP (Aurora)";
            font-size: 18px;
        }

        // ── Scan view ────────────────────────────────────────────────
        if !UiState.ftp-show-manual: VerticalLayout {
            spacing: 12px;

            if UiState.ftp-scanning: HorizontalLayout {
                spacing: 10px;

                Spinner {
                    width: 20px;
                    height: 20px;
                    indeterminate: true;
                }

                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Searching for your console on the network…";
                        wrap: word-wrap;
                    }
                }
            }

            if !UiState.ftp-scanning && UiState.ftp-scan-found-ip != "": Text {
                text: "Console found at " + UiState.ftp-scan-found-ip + ".";
                wrap: word-wrap;
            }

            if !UiState.ftp-scanning && UiState.ftp-scan-found-ip == "": Text {
                text: "No console found on the network.\nMake sure it is on with the FTP Server module started, or enter its details manually.";
                wrap: word-wrap;
            }
        }

        // ── Manual entry view ────────────────────────────────────────
        if UiState.ftp-show-manual: VerticalLayout {
            spacing: 10px;

            Text {
                text: "On the console, press Select to reveal its IP, then\nStart > Modules > FTP Server for the credentials.";
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 10px;

                VerticalLayout {
                    alignment: center;
                    width: 90px;

                    Text {
                        text: "Console IP:";
                    }
                }

                LineEdit {
                    width: 170px;
                    text: UiState.config.console-ip;
                    placeholder-text: "192.168.1.42";
                    edited => Dispatcher.dispatch(Message.SetConsoleIp, self.text);
                }

                VerticalLayout {
                    alignment: center;

                    Text {
                        text: "Port:";
                    }
                }

                LineEdit {
                    width: 60px;
                    text: UiState.config.ftp-port;
                    edited => Dispatcher.dispatch(Message.SetFtpPort, self.text);
                }
            }

            HorizontalLayout {
                spacing: 10px;

                VerticalLayout {
                    alignment: center;
                    width: 90px;

                    Text {
                        text: "User:";
                    }
                }

                LineEdit {
                    width: 110px;
                    text: UiState.config.ftp-user;
                    edited => Dispatcher.dispatch(Message.SetFtpUser, self.text);
                }

                VerticalLayout {
                    alignment: center;

                    Text {
                        text: "Password:";
                    }
                }

                LineEdit {
                    width: 110px;
                    text: UiState.config.ftp-password;
                    input-type: InputType.password;
                    edited => Dispatcher.dispatch(Message.SetFtpPassword, self.text);
                }
            }
        }
    }

    VerticalLayout {
        height: self.min-height;

        HorizontalLine { }

        HorizontalLayout {
            alignment: space-between;
            padding: 10px;
            spacing: 10px;

            // "Test connection" only makes sense once credentials are shown.
            if UiState.ftp-show-manual: IconButton {
                icon: IconSet.Cable;
                label: "Test connection";
                clicked => Dispatcher.dispatch(Message.TestFtp, "");
            }

            HorizontalLayout {
                alignment: space-between;
                spacing: 10px;

                IconButton {
                    label: "Cancel";
                    clicked => {
                        Dispatcher.dispatch(Message.CancelFtpScan, "");
                        UiState.editing-ftp-target = false;
                    }
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 10px;

                    // In the scan view, the manual-entry button sits just left of
                    // the primary button.
                    if !UiState.ftp-show-manual: IconButton {
                        icon: IconSet.Keyboard;
                        label: "Enter manually";
                        clicked => {
                            Dispatcher.dispatch(Message.CancelFtpScan, "");
                            UiState.ftp-show-manual = true;
                        }
                    }

                    // Always shown; disabled until a console is available (found by
                    // the scan, or entered manually).
                    IconButton {
                        icon: IconSet.MonitorUp;
                        label: "Use this console";
                        kind: IconButtonKind.Primary;
                        disabled: !UiState.ftp-show-manual && UiState.ftp-scan-found-ip == "";
                        clicked => {
                            Dispatcher.dispatch(Message.CancelFtpScan, "");
                            UiState.editing-ftp-target = false;
                            Dispatcher.dispatch(Message.SetTargetFtp, "");
                        }
                    }
                }
            }
        }
    }
}
