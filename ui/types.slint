export enum Page {
    Games,
    Toolbox,
    ConversionQueue,
    Settings,
    About,
}

export enum TargetKind {
    Local,
    Ftp,
}

export struct DisplayedConfig {
    path: string,
    // Displayed target: local path or ftp://ip. Empty if no target.
    target: string,
    target-kind: TargetKind,
    mount-point: string,
    remove-sources-games: string,
    xbox360-format: string,
    sort-by: string,
    view-as: string,
    theme-preference: string,
    auto-reconnect: string,
    show-x360: bool,
    show-arcade: bool,
    show-og: bool,
    console-ip: string,
    ftp-port: string,
    ftp-user: string,
    ftp-password: string,
}

export struct DisplayedBadAvatarConfig {
    // Effective URLs (user override or built-in default) shown in the fields.
    abadavatar-url: string,
    xeunshackle-url: string,
    aurora-url: string,
    system-update-url: string,
    // Built-in default URLs, so each field can offer a reset when it differs.
    abadavatar-default-url: string,
    xeunshackle-default-url: string,
    aurora-default-url: string,
    system-update-default-url: string,
    include-system-update: bool,
}

export struct DisplayedRecentLocation {
    // Folder name (local drive) or IP (console over FTP).
    name: string,
    is-ftp: bool,
}

export struct DisplayedGame {
    path: string,
    is-x360: bool,
    is-arcade: bool,
    format: string,
    size-gib: float,
    title: string,
    id: string,
    cover: image,
    // True when only DLC and/or a title update are installed, with no
    // actual game package (base install removed or never completed).
    incomplete: bool,
}

export struct DisplayedTitleUpdate {
    id: string,
    hash: string,
    name: string,
    version: string,
    size-text: string,
    // File name under 000B0000 when installed, empty otherwise.
    installed-file-name: string,
    is-active: bool,
    // True if Aurora already downloaded this update into its own cache
    // (the only case in which this app can activate it).
    is-cached: bool,
}

// One folder this app installs/scans on the console, and whether Aurora is
// configured to scan it (or an ancestor).
export struct DisplayedStoragePath {
    label: string,
    // FTP path (/Device/dir/…).
    path: string,
    // Same location in Aurora's "Manage Paths" format (Device:\dir\…).
    aurora-path: string,
    covered: bool,
}

export struct DisplayedDriveInfo {
    label: string,
    used-gib: float,
    games-gib: float,
    total-gib: float,
    fs-kind: string,
    allocation-granularity: int,
}

export struct Notification {
    text: string,
    critical: bool,
}
