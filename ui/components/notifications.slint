import { Card } from "card.slint";
import { IconButton } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component Notifications inherits TouchArea {
    width: v.width;
    height: v.height;

    v := VerticalLayout {
        width: self.preferred-width;
        height: self.preferred-height;
        padding: 10px;
        spacing: 5px;
        cross-axis-alignment: end;

        for notification[i] in UiState.notifications: card := Card {
            // Card hugs the text up to 400px: driven by the text's natural
            // (unwrapped) preferred-width, which - unlike its stretch-resolved
            // width - is unaffected by wrapping and safe to use here.
            width: min(t.preferred-width + 78px, 400px);
            min-height: 40px;

            h := HorizontalLayout {
                cross-axis-alignment: CrossAxisAlignment.center;
                spacing: 10px;
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 8px;
                padding-bottom: 8px;

                VerticalLayout {
                    alignment: start;
                    width: 14px;

                    IconDisplay {
                        icon: notification.critical ? IconSet.TriangleAlert : IconSet.Info;
                        size: 14px;
                        stroke: MyPalette.foreground;
                    }
                }

                t := Text {
                    // Explicit width (rather than horizontal-stretch) so the wrap
                    // preferred-height is computed against the actual rendered
                    // width instead of the unconstrained one: 78px = h's paddings
                    // (20px) + icon column (14px) + close column (24px) + spacing (20px).
                    width: card.width - 78px;
                    text: notification.text;
                    wrap: word-wrap;
                }

                VerticalLayout {
                    alignment: start;

                    IconButton {
                        icon: IconSet.X;
                        clicked => Dispatcher.dispatch(Message.CloseNotification, i);
                        rounded: true;
                        height: 24px;
                        width: 24px;
                    }
                }
            }
        }
    }
}
