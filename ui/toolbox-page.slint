import { IconSet, IconDisplay, Icon } from "@lucide";
import {
    ScrollView,
    LineEdit,
    CheckBox,
    ProgressIndicator,
    Spinner,
    HorizontalBox,
} from "std-widgets.slint";
import { MyPalette } from "styling.slint";
import { Card } from "components/card.slint";
import { HorizontalLine } from "components/horizontal-line.slint";
import { UiState } from "ui-state.slint";
import { Link } from "components/link.slint";
import { IconButton, IconButtonKind } from "components/icon-button.slint";
import { Message, Dispatcher } from "messages.slint";
import { TargetKind } from "types.slint";

// One editable BadAvatar download-URL row with a per-field reset button
// (shown only when the field differs from its built-in default).
component BadAvatarUrlField inherits VerticalLayout {
    in property <string> label;
    in property <string> url;
    in property <string> default-url;
    in property <string> field-key;
    spacing: 3px;

    // Editing a LineEdit breaks its `text: url` binding, so a later reset (url
    // reverting to the default) would leave the field stale. Push the value back
    // imperatively whenever `url` changes to keep the field in sync.
    changed url => {
        edit.text = url;
    }

    Text {
        text: label;
        font-size: 12px;
    }

    HorizontalLayout {
        spacing: 5px;

        edit := LineEdit {
            horizontal-stretch: 1;
            text: url;
            edited => Dispatcher.dispatch(Message.SetBadAvatarUrl, field-key + "\n" + self.text);
        }

        if url != default-url: IconButton {
            icon: IconSet.RotateCcw;
            width: self.height;
            clicked => Dispatcher.dispatch(Message.ResetBadAvatarUrl, field-key);
        }
    }
}

export component ToolboxPage inherits VerticalLayout {
    private property <int> optimal-allocation-granularity: (UiState.drive-info.total-gib <= 32) ? 32768 : 65536;
    private property <bool> is-optimal-allocation-granularity: UiState.drive-info.allocation-granularity == optimal-allocation-granularity;
    // Local toggle for the BadAvatar advanced (URL) settings section.
    private property <bool> show-badavatar-settings: false;

    init => {
        if UiState.config.target-kind == TargetKind.Ftp && !UiState.config.target.is-empty && !UiState.fetching-aurora-paths {
            Dispatcher.dispatch(Message.FetchAuroraPaths, "");
        }
    }

    pure function fs-icon(fs-kind: string) -> Icon {
        if fs-kind == "FAT32" {
            IconSet.Check
        } else {
            IconSet.TriangleAlert
        }
    }

    pure function fs-comment(fs-kind: string) -> string {
        if fs-kind == "FAT32" {
            "optimal choice for Xbox 360 USB storage"
        } else if fs-kind == "NTFS" || fs-kind == "exFAT" {
            "not readable by the Xbox 360 (fine for a local staging folder)"
        } else {
            "fine for a local staging folder, but not readable by the Xbox 360"
        }
    }

    pure function allocation-granularity-icon(optimal: bool) -> Icon {
        if optimal {
            IconSet.Check
        } else {
            IconSet.TriangleAlert
        }
    }

    pure function allocation-granularity-comment(optimal: bool) -> string {
        if optimal {
            "optimal"
        } else {
            "not optimal, but should work"
        }
    }

    HorizontalLayout {
        height: 58px;
        padding: 20px;
        padding-left: 10px;
        spacing: 5px;
        cross-axis-alignment: CrossAxisAlignment.center;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Toolbox";
            font-size: 18px;
        }
    }

    ScrollView {
        VerticalLayout {
            width: 100%;
            padding: 10px;
            padding-top: 0px;
            spacing: 10px;
            alignment: start;

            // Always available, regardless of the connected target.
            Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        alignment: LayoutAlignment.space-between;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        HorizontalLayout {
                            spacing: 5px;
                            cross-axis-alignment: CrossAxisAlignment.center;

                            IconDisplay {
                                icon: IconSet.Usb;
                                stroke: MyPalette.foreground;
                                size: 14px;
                            }

                            Text {
                                text: "BadAvatar USB key";
                            }
                        }

                        if UiState.fetching-aurora-paths: Spinner {
                            width: 27px;
                            height: 27px;
                            indeterminate: true;
                        }

                        if !UiState.fetching-aurora-paths: IconButton {
                            icon: IconSet.Settings2;
                            width: self.height;
                            clicked => {
                                show-badavatar-settings = !show-badavatar-settings;
                            }
                        }
                    }

                    HorizontalLine { }

                    Text {
                        text: "Creates a homebrew boot USB key (ABadAvatar + XeUnshackle + Aurora).\nPlug in a FAT32-formatted USB key first.";
                        wrap: word-wrap;
                    }

                    if show-badavatar-settings: VerticalLayout {
                        spacing: 8px;

                        HorizontalLine { }

                        Text {
                            text: "Download URLs — edit to use a different source, reset to restore the default:";
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        BadAvatarUrlField {
                            label: "ABadAvatar";
                            url: UiState.badavatar.abadavatar-url;
                            default-url: UiState.badavatar.abadavatar-default-url;
                            field-key: "abadavatar";
                        }

                        BadAvatarUrlField {
                            label: "XeUnshackle";
                            url: UiState.badavatar.xeunshackle-url;
                            default-url: UiState.badavatar.xeunshackle-default-url;
                            field-key: "xeunshackle";
                        }

                        BadAvatarUrlField {
                            label: "Aurora (.zip/.7z — the official .rar is not supported)";
                            url: UiState.badavatar.aurora-url;
                            default-url: UiState.badavatar.aurora-default-url;
                            field-key: "aurora";
                        }

                        CheckBox {
                            text: "Also download and add the official system update";
                            checked: UiState.badavatar.include-system-update;
                            toggled => {
                                Dispatcher.dispatch(Message.ToggleBadAvatarSystemUpdate, "");
                            }
                        }

                        if UiState.badavatar.include-system-update: BadAvatarUrlField {
                            label: "System update";
                            url: UiState.badavatar.system-update-url;
                            default-url: UiState.badavatar.system-update-default-url;
                            field-key: "system_update";
                        }
                    }

                    HorizontalLine { }

                    HorizontalLayout {
                        spacing: 10px;

                        bBadUsb := IconButton {
                            disabled: UiState.creating-badavatar;
                            icon: IconSet.Download;
                            width: self.height;
                            clicked => Dispatcher.dispatch(Message.CreateBadAvatar, "");
                        }

                        Text {
                            height: bBadUsb.height;
                            vertical-alignment: center;
                            text: !UiState.creating-badavatar ? "Create the BadAvatar USB key" : "Working… see the status bar below.";
                        }
                    }
                }
            }

            if UiState.config.target-kind == TargetKind.Local && !UiState.config.target.is-empty: Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 5px;

                        IconDisplay {
                            icon: IconSet.HardDrive;
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "Drive info";
                        }
                    }

                    HorizontalLine { }

                    HorizontalLayout {
                        spacing: 5px;

                        IconDisplay {
                            icon: fs-icon(UiState.drive-info.fs-kind);
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "Filesystem: \{UiState.drive-info.fs-kind}  (\{fs-comment(UiState.drive-info.fs-kind)})";
                        }
                    }

                    HorizontalLayout {
                        spacing: 5px;

                        IconDisplay {
                            icon: allocation-granularity-icon(is-optimal-allocation-granularity);
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "Allocation granularity: \{UiState.drive-info.allocation-granularity}  (\{allocation-granularity-comment(is-optimal-allocation-granularity)})";
                        }
                    }
                }
            }

            if UiState.config.target-kind == TargetKind.Ftp && !UiState.config.target.is-empty: Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 5px;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        IconDisplay {
                            icon: IconSet.MonitorUp;
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "Console (Aurora FTP)";
                        }
                    }

                    HorizontalLine { }

                    VerticalLayout {
                        height: self.min-height;

                        Text {
                            text: "The library is managed directly on the console at \{UiState.config.target}.\nOnce games are added, add the content paths in Aurora (Settings > Content Paths, Scan Depth 3+) and rescan.";
                            wrap: word-wrap;
                        }
                    }

                    HorizontalLine { }

                    HorizontalLayout {
                        spacing: 10px;

                        b0 := IconButton {
                            icon: IconSet.Cable;
                            width: self.height;
                            clicked => Dispatcher.dispatch(Message.TestFtp, "");
                        }

                        Text {
                            height: b0.height;
                            vertical-alignment: center;
                            text: "Test the FTP connection";
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;

                        b1 := IconButton {
                            icon: IconSet.RotateCw;
                            width: self.height;
                            clicked => Dispatcher.dispatch(Message.RestartAurora, "");
                        }

                        Text {
                            height: b1.height;
                            vertical-alignment: center;
                            text: "Restart Aurora";
                        }
                    }
                }
            }

            if UiState.config.target-kind == TargetKind.Ftp && !UiState.config.target.is-empty: Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        alignment: LayoutAlignment.space-between;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        HorizontalLayout {
                            spacing: 5px;
                            cross-axis-alignment: CrossAxisAlignment.center;

                            IconDisplay {
                                icon: IconSet.FolderSearch;
                                stroke: MyPalette.foreground;
                                size: 14px;
                            }

                            Text {
                                text: "Aurora scan paths";
                            }
                        }

                        if UiState.fetching-aurora-paths: Spinner {
                            width: 27px;
                            height: 27px;
                            indeterminate: true;
                        }

                        if !UiState.fetching-aurora-paths: IconButton {
                            icon: IconSet.RefreshCcw;
                            width: self.height;
                            clicked => {
                                if !UiState.fetching-aurora-paths {
                                    Dispatcher.dispatch(Message.FetchAuroraPaths, "");
                                }
                            }
                        }
                    }

                    HorizontalLine { }

                    if UiState.fetching-aurora-paths && !UiState.aurora-paths-loaded: Text {
                        text: "Reading Aurora's scan paths…";
                    }

                    // Read failure: reported here, not as a notification.
                    if !UiState.fetching-aurora-paths && UiState.aurora-paths-error != "": VerticalLayout {
                        spacing: 5px;

                        HorizontalLayout {
                            spacing: 5px;
                            cross-axis-alignment: CrossAxisAlignment.center;

                            IconDisplay {
                                icon: IconSet.TriangleAlert;
                                stroke: MyPalette.destructive;
                                size: 14px;
                            }

                            Text {
                                text: "Couldn't read Aurora's scan paths.";
                                color: MyPalette.destructive;
                            }
                        }

                        Text {
                            text: UiState.aurora-paths-error;
                            font-size: 12px;
                            wrap: word-wrap;
                            color: MyPalette.foreground.transparentize(0.4);
                        }
                    }

                    // Aurora scans nothing yet: warn and offer guidance.
                    if UiState.aurora-paths-error == "" && UiState.aurora-paths-loaded && UiState.aurora-scan-paths.length == 0: VerticalLayout {
                        height: self.min-height;
                        spacing: 8px;

                        HorizontalLayout {
                            spacing: 5px;
                            cross-axis-alignment: CrossAxisAlignment.center;

                            IconDisplay {
                                icon: IconSet.TriangleAlert;
                                stroke: #e0a12f;
                                size: 14px;
                            }

                            Text {
                                text: "Aurora isn't scanning any location.";
                                color: #e0a12f;
                            }
                        }

                        Text {
                            text: "No game will show up until you add scan paths in Aurora for your Xbox 360 (GOD) and OG Xbox games. Add them on the console, then refresh.";
                            wrap: word-wrap;
                        }

                        HorizontalLine { }

                        HorizontalLayout {
                            spacing: 10px;

                            b3 := IconButton {
                                icon: IconSet.CircleQuestionMark;
                                width: self.height;
                                clicked => { UiState.showing-aurora-help = true };
                            }

                            Text {
                                height: b3.height;
                                vertical-alignment: center;
                                text: "Help me add the content paths to Aurora";
                            }
                        }
                    }

                    if !UiState.fetching-aurora-paths && UiState.aurora-scan-paths.length > 0: VerticalLayout {
                        spacing: 3px;

                        Text {
                            text: "The following paths are scanned by Aurora :";
                        }

                        for path in UiState.aurora-scan-paths: Text {
                            text: "- " + path;
                            font-size: 12px;
                        }
                    }
                }
            }

            if !UiState.config.target.is-empty: Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 5px;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        IconDisplay {
                            icon: IconSet.Image;
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "Covers cache";
                        }
                    }

                    HorizontalLine { }

                    HorizontalLayout {
                        spacing: 10px;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        b := IconButton {
                            icon: IconSet.Play;
                            width: self.height;
                            clicked => Dispatcher.dispatch(Message.RedownloadAllCovers, "");
                        }

                        Text {
                            height: b.height;
                            vertical-alignment: center;
                            text: "Redownload all covers (clears the local cache first)";
                        }
                    }
                }
            }

            if Platform.os == OperatingSystemType.macos && UiState.config.target-kind == TargetKind.Local && !UiState.config.target.is-empty: Card {
                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 5px;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        IconDisplay {
                            icon: IconSet.Apple;
                            stroke: MyPalette.foreground;
                            size: 14px;
                        }

                        Text {
                            text: "macOS";
                        }
                    }

                    HorizontalLine { }

                    HorizontalLayout {
                        spacing: 10px;
                        cross-axis-alignment: CrossAxisAlignment.center;

                        b2 := IconButton {
                            icon: IconSet.Play;
                            width: self.height;
                            clicked => Dispatcher.dispatch(Message.RunDotClean, "");
                        }

                        Text {
                            height: b2.height;
                            vertical-alignment: center;
                            text: "Run dot_clean (removes ._ files that confuse the console)";
                        }
                    }
                }
            }
        }
    }
}
