import { Modal } from "modal.slint";
import { HorizontalLine } from "horizontal-line.slint";
import { IconButton, IconButtonKind } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component SelectTargetModal inherits Modal {
    VerticalLayout {
        padding: 20px;
        spacing: 15px;

        Text {
            text: "Where is your game library?";
            font-size: 18px;
        }

        IconButton {
            icon: IconSet.HardDrive;
            label: "Local drive / folder (USB FAT32)";
            clicked => {
                UiState.selecting-target = false;
                Dispatcher.dispatch(Message.PickMountPoint, "");
            }
        }

        IconButton {
            icon: IconSet.MonitorUp;
            label: "Console over FTP (Aurora)";
            clicked => {
                UiState.selecting-target = false;
                UiState.editing-ftp-target = true;
            }
        }

        if UiState.recent-locations.length > 0: HorizontalLine { }

        for loc[i] in UiState.recent-locations: HorizontalLayout {
            spacing: 8px;

            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;

                Text {
                    text: loc.name;
                    overflow: elide;
                }
            }

            IconButton {
                icon: loc.is-ftp ? IconSet.MonitorUp : IconSet.HardDrive;
                tooltip: "Connect";
                width: 30px;
                clicked => {
                    UiState.selecting-target = false;
                    Dispatcher.dispatch(Message.ConnectRecentLocation, i);
                }
            }

            IconButton {
                icon: IconSet.Trash;
                kind: IconButtonKind.Destructive;
                tooltip: "Remove from history";
                width: 30px;
                clicked => {
                    Dispatcher.dispatch(Message.RemoveRecentLocation, i);
                }
            }
        }
    }

    VerticalLayout {
        height: self.min-height;

        HorizontalLine { }

        HorizontalLayout {
            alignment: end;
            padding: 10px;

            IconButton {
                label: "Cancel";
                clicked => {
                    UiState.selecting-target = false;
                }
            }
        }
    }
}
