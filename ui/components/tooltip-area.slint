import { Tooltip } from "../tooltip.slint";
import { MyPalette } from "../styling.slint";

export component TooltipArea inherits Rectangle {
    in property <string> tooltip;
    out property <bool> has-hover: t.has-hover;
    in property <bool> disabled: false;
    // When > 0, holding the pointer for this long fires `long-pressed` on the
    // press instead of `clicked` on release. Opt-in, used for hidden debug
    // affordances; 0ms keeps the plain click-only behaviour.
    in property <duration> long-press-duration: 0ms;

    callback clicked;
    callback long-pressed;

    // Set once the long-press timer fired, so the release doesn't also click.
    property <bool> long-fired: false;

    r := Rectangle {
        @children
    }

    long-press-timer := Timer {
        interval: long-press-duration;
        running: false;
        triggered => {
            self.running = false;
            long-fired = true;
            Tooltip.text = "";
            long-pressed();
        }
    }

    if disabled: Rectangle {
        x: 0;
        y: 0;
        width: r.width;
        height: r.height;
        background: MyPalette.background.transparentize(0.4);
    }

    t := TouchArea {
        width: r.width;
        height: r.height;

        mouse-cursor: disabled ? MouseCursor.not-allowed : MouseCursor.default;

        clicked => {
            Tooltip.text = "";

            // Swallow the click that ends a long press.
            if long-fired {
                long-fired = false;
                return;
            }

            if !disabled {
                clicked();
            }
        }

        pointer-event(event) => {
            if event.kind == PointerEventKind.move {
                Tooltip.mouse-x = self.absolute-position.x + self.mouse-x;
                Tooltip.mouse-y = self.absolute-position.y + self.mouse-y;
            } else if event.kind == PointerEventKind.down {
                if long-press-duration > 0ms && !disabled {
                    long-fired = false;
                    long-press-timer.running = true;
                }
            } else if event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel {
                long-press-timer.running = false;
            }
        }

        changed has-hover => {
            if self.has-hover {
                Tooltip.text = tooltip;
                Tooltip.mouse-x = self.absolute-position.x + self.mouse-x;
                Tooltip.mouse-y = self.absolute-position.y + self.mouse-y;
            } else {
                Tooltip.text = "";
            }
        }
    }
}
