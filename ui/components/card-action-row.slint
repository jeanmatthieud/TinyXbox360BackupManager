import { Icon } from "@lucide";
import { IconButton } from "icon-button.slint";

// A footer action: a square IconButton followed by its descriptive label,
// vertically centred on the button.
export component CardActionRow inherits HorizontalLayout {
    in property <Icon> icon;
    in property <string> text;
    in property <bool> disabled;

    callback clicked();

    spacing: 10px;

    IconButton {
        icon: root.icon;
        width: self.height;
        disabled: root.disabled;
        clicked => {
            root.clicked();
        }
    }

    Text {
        vertical-alignment: center;
        text: root.text;
    }
}
