import { IconSet } from "@lucide";
import { Page } from "../types.slint";
import { NavbarButton } from "navbar-button.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component Navbar inherits VerticalLayout {
    alignment: LayoutAlignment.space-between;

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        NavbarButton {
            active: UiState.current-page == Page.Games;
            icon: IconSet.Gamepad2;
            tooltip: "Games";
            clicked => {
                UiState.current-page = Page.Games;
            }
        }

        // Always available: the Toolbox hosts the BadAvatar USB-key creation,
        // which is useful even when no target is connected.
        NavbarButton {
            active: UiState.current-page == Page.Toolbox;
            icon: IconSet.ToolCase;
            tooltip: "Toolbox";
            clicked => {
                UiState.current-page = Page.Toolbox;
            }
        }

        NavbarButton {
            active: UiState.current-page == Page.Settings;
            icon: IconSet.Settings;
            tooltip: "Settings";
            clicked => {
                UiState.current-page = Page.Settings;
            }
        }
    }

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        if UiState.conversion-queue.length > 0: NavbarButton {
            active: UiState.current-page == Page.ConversionQueue;
            icon: IconSet.RefreshCw;
            tooltip: "Conversion queue";
            rotate: true;
            clicked => {
                UiState.current-page = Page.ConversionQueue;
            }
        }

        if !UiState.latest-version.is-empty: NavbarButton {
            icon: IconSet.BellPlus;
            tooltip: "New TinyXbox360BackupManager version available: \{UiState.latest-version}";
            clicked => Dispatcher.dispatch(Message.OpenThat, "https://github.com/jeanmatthieud/TinyXbox360BackupManager/releases/latest");
        }

        if UiState.config.target.is-empty: NavbarButton {
            icon: IconSet.Zap;
            ping: true;
            tooltip: "Select a target";
            clicked => {
                UiState.selecting-target = true;
            }
        }

        if !UiState.config.target.is-empty: NavbarButton {
            icon: IconSet.Unplug;
            tooltip: "Disconnect from \{UiState.config.target}";
            clicked => Dispatcher.dispatch(Message.Disconnect, "");
        }

        NavbarButton {
            active: UiState.current-page == Page.About;
            icon: IconSet.Info;
            tooltip: "About TinyXbox360BackupManager";
            clicked => {
                UiState.current-page = Page.About;
            }
        }
    }
}
