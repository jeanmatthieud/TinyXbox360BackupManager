import { HomebrewAppsFilter } from "homebrew-apps-filter.slint";
import { UiState } from "../ui-state.slint";

export component HomebrewAppsOtherToolbar inherits HorizontalLayout {
    alignment: space-between;
    height: 38px;
    padding-right: 10px;

    HomebrewAppsFilter { }

    Text {
        height: parent.height;
        vertical-alignment: center;
        horizontal-alignment: end;
        text: "\{UiState.homebrew-apps.length} app\{UiState.homebrew-apps.length == 1 ? "" : "s"}   ~ \{UiState.drive-info.apps-mib.to-fixed(2)} MiB";
    }
}
