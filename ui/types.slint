export enum Page {
    Games,
    HomebrewApps,
    Osc,
    Toolbox,
    ConversionQueue,
    Settings,
    About,
}

export struct DisplayedConfig {
    path: string,
    mount-point: string,
    always-split: string,
    remove-sources-apps: string,
    remove-sources-games: string,
    scrub-update-partition: string,
    sort-by: string,
    view-as: string,
    wii-ip: string,
    txt-codes-source: string,
    theme-preference: string,
    wii-output-format: string,
    gc-output-format: string,
    show-wii: bool,
    show-gc: bool,
    preferred-language: string,
}

export struct DisplayedDiscInfo {
    path: string,
    format: string,
    game-id: string,
    game-title: string,
    region: string,
    is-wii: bool,
    is-gc: bool,
    disc-number: int,
    disc-version: int,
    is-worth-scrubbing: bool,
    crc32: string,
}

export struct DisplayedGame {
    path: string,
    is-wii: bool,
    size-gib: float,
    title: string,
    id: string,
    cover: image,
}

export struct DisplayedOscApp {
    slug: string,
    name: string,
    author: string,
    version: string,
    uncompressed-size-mib: float,
    release-date: string,
    short-description: string,
    long-description: string,
    release-date: string,
    icon: image,
}

export struct DisplayedHomebrewApp {
    path: string,
    slug: string,
    size-mib: float,
    name: string,
    coder: string,
    version: string,
    release-date: string,
    short-description: string,
    long-description: string,
    icon: image,
    osc-app: DisplayedOscApp,
}

export struct DisplayedDriveInfo {
    label: string,
    used-gib: float,
    games-gib: float,
    apps-mib: float,
    total-gib: float,
    fs-kind: string,
    allocation-granularity: int,
}

export struct Notification {
    text: string,
    critical: bool,
}
