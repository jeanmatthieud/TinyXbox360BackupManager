import { ScrollView, Palette } from "std-widgets.slint";
import { IconSet, IconDisplay } from "@lucide";
import { SettingCard } from "components/setting-card.slint";
import { MyPalette } from "styling.slint";
import { UiState } from "ui-state.slint";
import { Message, Dispatcher } from "messages.slint";

export component SettingsPage inherits VerticalLayout {
    HorizontalLayout {
        height: 58px;
        padding: 20px;
        padding-left: 10px;
        spacing: 5px;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Settings";
            font-size: 18px;
        }
    }

    ScrollView {
        VerticalLayout {
            width: 100%;
            padding: 10px;
            padding-top: 0px;
            spacing: 10px;
            alignment: start;

            SettingCard {
                icon: IconSet.Disc3;
                label: "Wii output format";
                items: [
                    { value: "Wbfs", label: "WBFS (recommended)" },
                    { value: "Iso", label: "ISO (very large)" }
                ];
                active-item: UiState.config.wii-output-format;
                set-property: Message.SetWiiOutputFormat;
            }

            SettingCard {
                icon: IconSet.Disc3;
                label: "GameCube output format";
                items: [
                    { value: "Iso", label: "ISO (recommended)" },
                    {
                        value: "Ciso",
                        label: "CISO (much smaller, slightly slower, less metadata in game loaders)"
                    }
                ];
                active-item: UiState.config.gc-output-format;
                set-property: Message.SetGcOutputFormat;
            }

            SettingCard {
                icon: IconSet.SquareSplitHorizontal;
                label: "Split output";
                items: [
                    { value: "false", label: "Only when needed (recommended)" },
                    { value: "true", label: "Always 4GB-32KB" }
                ];
                active-item: UiState.config.always-split;
                set-property: Message.SetAlwaysSplit;
            }

            SettingCard {
                icon: IconSet.FileMinusCorner;
                label: "Remove update partition on WBFS/CISO";
                items: [
                    { value: "false", label: "No (recommended)" },
                    {
                        value: "true",
                        label: "Yes (saves some space; update partition is zeroed, but still there)"
                    }
                ];
                active-item: UiState.config.scrub-update-partition;
                set-property: Message.SetScrubUpdatePartition;
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding games";
                items: [{ value: "false", label: "No (recommended)" }, { value: "true", label: "Yes" }];
                active-item: UiState.config.remove-sources-games;
                set-property: Message.SetRemoveSourcesGames;
            }

            SettingCard {
                icon: IconSet.Trash;
                label: "Delete sources when adding apps";
                items: [{ value: "false", label: "No (recommended)" }, { value: "true", label: "Yes" }];
                active-item: UiState.config.remove-sources-apps;
                set-property: Message.SetRemoveSourcesApps;
            }

            SettingCard {
                icon: IconSet.Skull;
                label: "Cheat codes source";
                items: [
                    { value: "WebArchive", label: "geckocodes.org-201909 archive (recommended)" },
                    { value: "GameHacking", label: "gamehacking.org (up to date)" },
                    { value: "Rc24", label: "codes.rc24.xyz" }
                ];
                active-item: UiState.config.txt-codes-source;
                set-property: Message.SetTxtCodesSource;
            }

            SettingCard {
                icon: IconSet.SunMoon;
                label: "Theme";
                items: [
                    { value: "System", label: "System (requires restart)" },
                    { value: "Light", label: "Light" },
                    { value: "Dark", label: "Dark" }
                ];
                active-item: UiState.config.theme-preference;
                set-property: Message.SetThemePreference;

                changed() => {
                    if UiState.config.theme-preference == "Light" {
                        Palette.color-scheme = ColorScheme.light;
                    } else if UiState.config.theme-preference == "Dark" {
                        Palette.color-scheme = ColorScheme.dark;
                    }
                }
            }

            SettingCard {
                icon: IconSet.ImageDown;
                label: "Preferred language for PAL covers";
                items: [
                    { value: "English", label: "English" },
                    { value: "French", label: "French" },
                    { value: "German", label: "German" },
                    { value: "Spanish", label: "Spanish" },
                    { value: "Italian", label: "Italian" },
                    { value: "Dutch", label: "Dutch" },
                    { value: "Portuguese", label: "Portuguese" },
                    { value: "Swedish", label: "Swedish" },
                    { value: "Danish", label: "Danish" },
                    { value: "Finnish", label: "Finnish" }
                ];
                active-item: UiState.config.preferred-language;
                set-property: Message.SetPreferredLanguage;
            }
        }
    }
}
