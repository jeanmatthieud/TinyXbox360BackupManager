import { IconSet, IconDisplay } from "@lucide";
import { MyPalette } from "../styling.slint";

export component NoDrive inherits VerticalLayout {
    alignment: center;

    HorizontalLayout {
        spacing: 5px;
        alignment: center;

        IconDisplay {
            icon: IconSet.MoveDownLeft;
            stroke: MyPalette.foreground;
            size: 14px;
        }

        Text {
            text: "Click on";
        }

        IconDisplay {
            icon: IconSet.HardDrive;
            stroke: MyPalette.foreground;
            size: 14px;
        }

        Text {
            text: "to select a drive or a console (FTP)";
        }
    }
}
