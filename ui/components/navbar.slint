import { IconSet } from "@lucide";
import { Page } from "../types.slint";
import { NavbarButton } from "navbar-button.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component Navbar inherits VerticalLayout {
    alignment: LayoutAlignment.space-between;

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        NavbarButton {
            active: UiState.current-page == Page.Games;
            icon: IconSet.Gamepad2;
            tooltip: "Games";
            clicked => {
                UiState.current-page = Page.Games;
            }
        }

        NavbarButton {
            active: UiState.current-page == Page.HomebrewApps;
            icon: IconSet.WavesHorizontal;
            icon2: IconSet.Bubbles;
            tooltip: "Homebrew apps";
            clicked => {
                UiState.current-page = Page.HomebrewApps;
            }
        }

        NavbarButton {
            active: UiState.current-page == Page.Osc;
            icon: IconSet.WavesHorizontal;
            icon2: IconSet.ArrowBigDown;
            tooltip: "Open Shop Channel";
            clicked => {
                UiState.current-page = Page.Osc;
                Dispatcher.dispatch(Message.DownloadOscIcons, "");
            }
        }

        NavbarButton {
            active: UiState.current-page == Page.Toolbox;
            icon: IconSet.ToolCase;
            tooltip: "Toolbox";
            clicked => {
                UiState.current-page = Page.Toolbox;
            }
        }

        NavbarButton {
            active: UiState.current-page == Page.Settings;
            icon: IconSet.Settings;
            tooltip: "Settings";
            clicked => {
                UiState.current-page = Page.Settings;
            }
        }
    }

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        if UiState.conversion-queue.length > 0: NavbarButton {
            active: UiState.current-page == Page.ConversionQueue;
            icon: IconSet.RefreshCw;
            tooltip: "Conversion queue";
            rotate: true;
            clicked => {
                UiState.current-page = Page.ConversionQueue;
            }
        }

        if !UiState.latest-version.is-empty: NavbarButton {
            icon: IconSet.BellPlus;
            tooltip: "New TinyWiiBackupManager version available: \{UiState.latest-version}";
            clicked => Dispatcher.dispatch(Message.OpenThat, "https://github.com/mq1/TinyWiiBackupManager/releases/latest");
        }

        NavbarButton {
            icon: IconSet.HardDrive;
            tooltip: "Select a drive";
            clicked => Dispatcher.dispatch(Message.PickMountPoint, "");
        }

        NavbarButton {
            active: UiState.current-page == Page.About;
            icon: IconSet.Info;
            tooltip: "About TinyWiiBackupManager";
            clicked => {
                UiState.current-page = Page.About;
            }
        }
    }
}
