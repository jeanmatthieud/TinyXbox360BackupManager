import { ShowX360Og } from "show-x360-og.slint";
import { IconButton, IconButtonKind } from "icon-button.slint";
import { IconSet, IconDisplay } from "@lucide";
import { SortGamesAndHomebrewApps } from "sort-games-and-homebrew-apps.slint";
import { ViewAs } from "view-as.slint";
import { MyPalette } from "../styling.slint";
import { UiState } from "../ui-state.slint";
import { Message, Dispatcher } from "../messages.slint";

export component GamesToolbar inherits HorizontalLayout {
    alignment: space-between;
    height: 38px;

    HorizontalLayout {
        padding-top: 10px;
        spacing: 5px;

        IconDisplay {
            icon: IconSet.ChevronRight;
            size: 18px;
            stroke: MyPalette.foreground;
        }

        Text {
            text: "Games";
            font-size: 18px;
        }
    }

    if !UiState.config.target.is-empty: HorizontalLayout {
        spacing: 10px;

        ShowX360Og { }

        SortGamesAndHomebrewApps { }

        ViewAs { }

        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                spacing: 10px;

                IconButton {
                    icon: IconSet.RotateCw;
                    tooltip: "Refresh games";
                    rounded: true;
                    kind: IconButtonKind.Primary;
                    font-size: 18px;
                    width: 34px;
                    height: 34px;
                    clicked => Dispatcher.dispatch(Message.RefreshAll, "");
                }

                IconButton {
                    icon: IconSet.Plus;
                    tooltip: "Add new games (ISO)";
                    rounded: true;
                    kind: IconButtonKind.Primary;
                    font-size: 18px;
                    width: 34px;
                    height: 34px;
                    clicked => Dispatcher.dispatch(Message.PickGames, "false");
                }

                IconButton {
                    icon: IconSet.FolderPlus;
                    tooltip: "Add new games from a folder (recursively)";
                    rounded: true;
                    kind: IconButtonKind.Primary;
                    font-size: 18px;
                    width: 34px;
                    height: 34px;
                    clicked => Dispatcher.dispatch(Message.PickGames, "true");
                }
            }
        }
    }
}
