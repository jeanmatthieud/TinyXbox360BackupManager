import { Card } from "card.slint";

// Outer shell shared by every Toolbox card: a full-width Card whose body is a
// padded, evenly-spaced vertical stack. Drop the card content (header, lines,
// body, action rows) straight in as children.
export component ToolboxCard inherits Card {
    width: 100%;

    VerticalLayout {
        padding: 10px;
        spacing: 10px;

        @children
    }
}
